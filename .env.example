# Subsonic Music Player Configuration
# Copy this to .env and fill in your Subsonic server details

SUBSONIC_SERVER_URL=http://your-subsonic-server.com
SUBSONIC_USERNAME=your_username
SUBSONIC_PASSWORD=your_password
SUBSONIC_CLIENT_NAME=SubsonicPythonPlayer
SUBSONIC_API_VERSION=1.16.1

# API Server
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=false
